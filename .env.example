# Database Connection String (PostgreSQL)
# For Local Host:
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"
# For Docker Container:
# DATABASE_URL="postgresql://postgres:admin@db:5432/db_gmf?schema=public"

# JWT Secret Key for Authentication
JWT_SECRET="your_super_secret_jwt_key_here"

# ============================================================
# AI SERVICE CONFIGURATION (SERVICE BULLETIN)
# ============================================================
AI_SERVICE_URL="https://example-sb-extractor.hf.space/api/extract"
AI_SERVICE_API_KEY="your_huggingface_api_key_here"

# ============================================================
# AI SERVICE CONFIGURATION (SHOP VISIT REPORT - SVR)
# ============================================================
SVR_AI_SERVICE_URL="https://example-svr-extractor.hf.space/api/extract_svr"
SVR_AI_SERVICE_API_KEY="your_svr_api_key_here"

# ============================================================
# AI SERVICE CONFIGURATION (ENGINE DATA SHEET - EDS)
# ============================================================
EDS_AI_SERVICE_URL="https://example-eds-extractor.hf.space/api/extract_eds"
EDS_AI_SERVICE_API_KEY="your_eds_api_key_here"

# ============================================================
# AI SERVICE CONFIGURATION (IQ03 REPORT)
# ============================================================
IQ03_AI_SERVICE_URL="https://example-iq03-extractor.hf.space/api/extract_iq03"
IQ03_AI_SERVICE_API_KEY="your_iq03_api_key_here"
