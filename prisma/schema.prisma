// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum Role {
  ADMIN
  TECHNICIAN
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  CANCELLED
  CLOSED
}

enum ComplianceStatus {
  NOT_APPLICABLE
  OPEN
  IN_PROGRESS
  COMPLIED
  DEFERRED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskType {
  INSPECTION
  MODIFICATION
  REPLACEMENT
  REPAIR
  SOFTWARE_UPDATE
  RECORD_REVIEW
  OTHER
}

enum OcrProcessingStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  REVIEW_REQUIRED
  FAILED
}

enum OcrDraftStatus {
  DRAFT
  REVIEW_REQUIRED
  VALIDATED
  GENERATED
}

// SB Category Type for UI badge display
enum SbType {
  MANDATORY
  RECOMMENDED
  ALERT
  ADVISORY
}

// Engineering recommendation action
enum EngRecAction {
  COMPLY
  DEFER
  NA
}

// --- AUTH & USER ---
model User {
  id        String   @id
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(TECHNICIAN)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  uploadedServiceBulletins ServiceBulletin[]           @relation("ServiceBulletinCreator")
  updatedServiceBulletins  ServiceBulletin[]           @relation("ServiceBulletinUpdater")
  engineeringRecs          EngineeringRecommendation[]
}

// --- ASSETS ---
model Aircraft {
  id              String           @id
  registration    String           @unique
  msn             String?          @unique
  aircraftType    String
  operator        String?
  active          Boolean          @default(true)
  engines         Engine[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt
}

model Engine {
  id         String    @id
  esn        String    @unique
  msn        String?
  model      String
  position   String?
  aircraftId String?
  aircraft   Aircraft? @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  active     Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  shopVisitReports      ShopVisitReport[]
  complianceRecords     ComplianceRecord[]
  svrConfigurationItems SvrConfigurationItem[]
  svrLlpStatuses        SvrLlpStatus[]
  svrAdStatuses         SvrAdStatus[]
}

// --- DOCUMENTS (AD, SB, EES) ---

// 1. Airworthiness Directive (AD)
model AirworthinessDirective {
  id        String         @id
  adNumber  String         @unique
  title     String
  issuer    String
  issueDate DateTime
  dueDate   DateTime?
  status    DocumentStatus @default(ACTIVE)

  createdAt       DateTime         @default(now())
  complianceRecords ComplianceRecord[]
}

// 2. Service Bulletin (SB) - Sumber dokumen untuk OCR & Unified Model
model ServiceBulletin {
  id               String              @id
  sbNumber         String              @unique
  title            String
  issuer           String
  issueDate        DateTime
  status           DocumentStatus      @default(ACTIVE)

  // Applicability / Classification fields (from company DB or AI)
  sbType           SbType?
  complianceCategory Int?
  effectivityType  String?
  effectivityRange String?
  compliancePeriod String?

  // File Upload fields
  originalFileName String?
  storedFileName   String?
  createdById      String?
  createdBy        User?               @relation("ServiceBulletinCreator", fields: [createdById], references: [id])

  updatedById      String?
  updatedBy        User?               @relation("ServiceBulletinUpdater", fields: [updatedById], references: [id])

  // Relations
  ocrResult      OcrResult?
  generatedEes   EesDocument?
  engineeringRec EngineeringRecommendation?
  createdAt      DateTime            @default(now())
  complianceRecords ComplianceRecord[]
}

model OcrResult {
  id                String              @id @default(uuid())
  serviceBulletinId String              @unique
  serviceBulletin   ServiceBulletin     @relation(fields: [serviceBulletinId], references: [id], onDelete: Cascade)
  
  ocrStatus         OcrProcessingStatus @default(UPLOADED)
  draftStatus       OcrDraftStatus      @default(DRAFT)
  rawPayload        Json?
  extractedAt       DateTime?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now()) @updatedAt
}

// 3. EES (Engineering Evaluation Sheet) - Hasil AI
model EesDocument {
  id        String @id
  eesNumber String @unique

  sourceSbId String          @unique
  sourceSb   ServiceBulletin @relation(fields: [sourceSbId], references: [id], onDelete: Cascade)

  // Dokumen Global Fields
  taskType       String?
  references     String?
  effectedType   String?
  effectedModel  String?
  
  aircraftType   String?
  
  esn            String?

  storedGarudaPdfPath    String?
  storedCitilinkPdfPath  String?
  storedExcelPath        String?

  evaluations     EesEvaluationItem[]
  createdAt       DateTime            @default(now())
}

model EesEvaluationItem {
  id              String      @id
  eesDocumentId   String
  eesDocument     EesDocument @relation(fields: [eesDocumentId], references: [id], onDelete: Cascade)
  itemNo          String
  paragraph       String?
  requirementDesc String      @db.Text
  remarks         String?     @db.Text
  taskType        String?
  adRelated       String?
  warranty        Boolean?
  rep             String?
  dueAt           DateTime?
  isApplicable    Boolean     @default(true)
}

// 4. Engineering Recommendation — Step 4 of EES Workflow (user input)
model EngineeringRecommendation {
  id                String       @id
  sbId              String       @unique
  sb                ServiceBulletin @relation(fields: [sbId], references: [id], onDelete: Cascade)

  recommendedAction EngRecAction
  priorityLevel     Priority     @default(HIGH)
  engineeringNotes  String?      @db.Text
  isDeferable       Boolean      @default(false)
  egtMarginCheck    Boolean      @default(false)

  createdById       String?
  createdBy         User?        @relation(fields: [createdById], references: [id])

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
}

// --- SHOP VISIT REPORTS (SVR) ---

model ShopVisitReport {
  id                       String                 @id @default(uuid())
  engineSerialNumber       String
  engineId                 String?
  engine                   Engine?                @relation(fields: [engineId], references: [id], onDelete: SetNull)
  engineType               String?
  shopInDate               String?                // Stored as string to keep exact format
  shopOutDate              String?                // Stored as string to keep exact format
  reportDate               String?                // Clarified field for SVR report date
  reasonForShopVisit       String?                @db.Text
  tsn                      String?
  csn                      String?
  tslv                     String?
  cslv                     String?
  authorizedReleaseStatus  String?
  originalFileName         String?
  storedFileName           String?
  rawPayload               Json?
  
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @default(now()) @updatedAt

  configurationReport      SvrConfigurationItem[]
  llpStatus                SvrLlpStatus[]
  adStatus                 SvrAdStatus[]
  complianceRecords        ComplianceRecord[]
}

model SvrConfigurationItem {
  id                 String          @id @default(uuid())
  svrId              String
  svr                ShopVisitReport @relation(fields: [svrId], references: [id], onDelete: Cascade)
  engineSerialNumber String?         // Added for grouping by ESN
  engineId           String?
  engine             Engine?         @relation(fields: [engineId], references: [id], onDelete: SetNull)
  module             String?
  partName           String?
  inOut              String?         // "IN" or "OUT"
  partNumber         String?
  serial             String?
  qty                String?
  tsn                String?
  csn                String?
  tso                String?
  cso                String?
  workAccompl        String?
}

model SvrLlpStatus {
  id                  String          @id @default(uuid())
  svrId               String
  svr                 ShopVisitReport @relation(fields: [svrId], references: [id], onDelete: Cascade)
  engineSerialNumber  String?         // Added for grouping by ESN
  engineId            String?
  engine              Engine?         @relation(fields: [engineId], references: [id], onDelete: SetNull)
  no                  String?
  description         String?
  partNumber          String?
  serialNumber        String?
  totalHour           String?
  totalCycle          String?
  totalCyclesCategory Json?           // Dynamic categories
  lifeLimitCycles     Json?           // Dynamic categories
  remainingCycles     Json?           // Dynamic categories
  remark              String?
}

model SvrAdStatus {
  id                            String          @id @default(uuid())
  svrId                         String
  svr                           ShopVisitReport @relation(fields: [svrId], references: [id], onDelete: Cascade)
  engineSerialNumber            String?         // Added for grouping by ESN
  engineId                      String?
  engine                        Engine?         @relation(fields: [engineId], references: [id], onDelete: SetNull)
  adNumber                      String?
  notificationDateOfCompliance  String?
  description                   String?
  referenceSb                   String?
  recurrInsp                    String?
  moduleApplicability           String?
  methodOfCompliance            String?
  remarks                       String?         @db.Text
}

model ComplianceRecord {
  id             String           @id @default(uuid())
  engineId       String
  engine         Engine           @relation(fields: [engineId], references: [id], onDelete: Cascade)
  sbId           String?
  sb             ServiceBulletin? @relation(fields: [sbId], references: [id], onDelete: Cascade)
  adId           String?
  ad             AirworthinessDirective? @relation(fields: [adId], references: [id], onDelete: Cascade)
  status         ComplianceStatus @default(OPEN)
  complianceDate String?          // Stored as string to preserve format
  svrId          String?
  svr            ShopVisitReport? @relation(fields: [svrId], references: [id], onDelete: SetNull)
  remarks        String?          @db.Text

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now()) @updatedAt

  @@unique([engineId, sbId])
  @@unique([engineId, adId])
}

