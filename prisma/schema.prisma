// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum Role {
  ADMIN
  TECHNICIAN
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  CANCELLED
  CLOSED
}

enum ComplianceStatus {
  NOT_APPLICABLE
  OPEN
  IN_PROGRESS
  COMPLIED
  DEFERRED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskType {
  INSPECTION
  MODIFICATION
  REPLACEMENT
  REPAIR
  SOFTWARE_UPDATE
  RECORD_REVIEW
  OTHER
}

enum OcrProcessingStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  REVIEW_REQUIRED
  FAILED
}

enum OcrDraftStatus {
  DRAFT
  REVIEW_REQUIRED
  VALIDATED
  GENERATED
}

// SB Category Type for UI badge display
enum SbType {
  MANDATORY
  RECOMMENDED
  ALERT
  ADVISORY
}

// Engineering recommendation action
enum EngRecAction {
  COMPLY
  DEFER
  NA
}

// --- AUTH & USER ---
model User {
  id        String   @id
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(TECHNICIAN)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  assignedComplianceTasks  ComplianceTask[]           @relation("ComplianceTaskAssignee")
  createdComplianceTasks   ComplianceTask[]            @relation("ComplianceTaskCreator")
  uploadedServiceBulletins ServiceBulletin[]           @relation("ServiceBulletinCreator")
  updatedServiceBulletins  ServiceBulletin[]           @relation("ServiceBulletinUpdater")
  engineeringRecs          EngineeringRecommendation[]
}

// --- ASSETS ---
model Aircraft {
  id              String           @id
  registration    String           @unique
  msn             String?          @unique
  aircraftType    String
  operator        String?
  active          Boolean          @default(true)
  engines         Engine[]
  complianceTasks ComplianceTask[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt
}

model Engine {
  id         String    @id
  esn        String    @unique
  msn        String?
  model      String
  position   String?
  aircraftId String?
  aircraft   Aircraft? @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  active     Boolean   @default(true)

  complianceTasks ComplianceTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// --- DOCUMENTS (AD, SB, EES) ---

// 1. Airworthiness Directive (AD)
model AirworthinessDirective {
  id        String         @id
  adNumber  String         @unique
  title     String
  issuer    String
  issueDate DateTime
  dueDate   DateTime?
  status    DocumentStatus @default(ACTIVE)

  complianceTasks ComplianceTask[]
  createdAt       DateTime         @default(now())
}

// 2. Service Bulletin (SB) - Sumber dokumen untuk OCR & Unified Model
model ServiceBulletin {
  id               String              @id
  sbNumber         String              @unique
  title            String
  issuer           String
  issueDate        DateTime
  status           DocumentStatus      @default(ACTIVE)

  // Applicability / Classification fields (from company DB or AI)
  sbType           SbType?
  complianceCategory Int?
  effectivityType  String?
  effectivityRange String?
  compliancePeriod String?

  // File Upload fields
  originalFileName String?
  storedFileName   String?
  ocrStatus        OcrProcessingStatus @default(UPLOADED)
  createdById      String?
  createdBy        User?               @relation("ServiceBulletinCreator", fields: [createdById], references: [id])

  updatedById      String?
  updatedBy        User?               @relation("ServiceBulletinUpdater", fields: [updatedById], references: [id])

  // AI Draft fields
  rawPayload       Json?
  draftStatus      OcrDraftStatus      @default(DRAFT)
  extractedAt      DateTime?

  // Relations
  generatedEes   EesDocument?
  engineeringRec EngineeringRecommendation?
  complianceTasks ComplianceTask[]
  createdAt        DateTime            @default(now())
}

// 3. EES (Engineering Evaluation Sheet) - Hasil AI
model EesDocument {
  id        String @id
  eesNumber String @unique

  sourceSbId String          @unique
  sourceSb   ServiceBulletin @relation(fields: [sourceSbId], references: [id], onDelete: Cascade)

  // Dokumen Global Fields
  taskType       String?
  references     String?
  effectedType   String?
  effectedModel  String?
  esn            String?

  storedPdfPath  String?

  evaluations     EesEvaluationItem[]
  complianceTasks ComplianceTask[]
  createdAt       DateTime            @default(now())
}

model EesEvaluationItem {
  id              String      @id
  eesDocumentId   String
  eesDocument     EesDocument @relation(fields: [eesDocumentId], references: [id], onDelete: Cascade)
  itemNo          String
  paragraph       String?
  requirementDesc String      @db.Text
  remarks         String?     @db.Text
  taskType        String?
  adRelated       String?
  warranty        Boolean?
  rep             String?
  dueAt           DateTime?
  isApplicable    Boolean     @default(true)

  complianceTaskId String?
  complianceTask   ComplianceTask? @relation(fields: [complianceTaskId], references: [id])
}

// 4. Engineering Recommendation — Step 4 of EES Workflow (user input)
model EngineeringRecommendation {
  id                String       @id
  sbId              String       @unique
  sb                ServiceBulletin @relation(fields: [sbId], references: [id], onDelete: Cascade)

  recommendedAction EngRecAction
  priorityLevel     Priority     @default(HIGH)
  engineeringNotes  String?      @db.Text
  isDeferable       Boolean      @default(false)
  egtMarginCheck    Boolean      @default(false)

  createdById       String?
  createdBy         User?        @relation(fields: [createdById], references: [id])

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
}

// --- COMPLIANCE ---
model ComplianceTask {
  id     String           @id
  title  String
  status ComplianceStatus @default(OPEN)

  adId String?
  ad   AirworthinessDirective? @relation(fields: [adId], references: [id])

  sbId String?
  sb   ServiceBulletin? @relation(fields: [sbId], references: [id])

  eesId String?
  ees   EesDocument? @relation(fields: [eesId], references: [id])

  aircraftId String?
  aircraft   Aircraft? @relation(fields: [aircraftId], references: [id])

  engineId String?
  engine   Engine? @relation(fields: [engineId], references: [id])

  assignedToId String?
  assignedTo   User? @relation("ComplianceTaskAssignee", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User? @relation("ComplianceTaskCreator", fields: [createdById], references: [id])

  eesEvaluationItems EesEvaluationItem[]

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}
